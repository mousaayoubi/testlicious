<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
<table name="vendor_notes" resource="default" engine="innodb" comment="Notes Table">
	<column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true" comment="ID" />
	<column xsi:type="varchar" name="title" length="255" nullable="false" coment="Title" />
	<column xsi:type="text" name="content" nullable="true" comment="Content" />
	<column xsi:type="int" name="priority" nullable="true" comment="Priority" />
	<column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At" />
	<constraint xsi:type="primary" referenceId="PRIMARY">
		<column name="entity_id" />
	</constraint>
</table>
</schema>
